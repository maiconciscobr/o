{
  "name": "o",
  "private": true,
  "version": "0.1.0",
  "description": "Dashboard para power users do Claude Code",
  "license": "MIT",
  "workspaces": [
    "apps/web",
    "apps/server",
    "packages/mcp"
  ],
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
